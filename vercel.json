{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["admin.html"] }
    }
  ],
  "routes": [
    { "src": "/admin.html", "dest": "/server.js" },
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/admin", "dest": "/server.js" }
  ]
}
